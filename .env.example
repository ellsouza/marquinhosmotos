# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marquinhos_motos?schema=public"
# Use 1 para usar o catálogo no banco (Prisma). Coloque 0 para usar o catálogo de exemplo.
MM_ENABLE_DB="0"

# App auth (JWT)
AUTH_SECRET="change-me-to-a-long-random-string"
MM_JWT_ISSUER="marquinhos-motos"
MM_JWT_AUDIENCE="web"

# Stripe (optional, for real card checkout)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# OAuth (opcional)
# Google (OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple (Sign in with Apple)
# APPLE_PRIVATE_KEY: chave .p8 (pode usar \\n para quebras de linha no .env)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Public site config
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Marquinhos Motos Mecânica Geral"
NEXT_PUBLIC_STORE_CITY="Barueri"
NEXT_PUBLIC_STORE_STATE="SP"
NEXT_PUBLIC_HERO_HEADLINE="Peças e serviços para motos — atendimento rápido em Barueri/SP"
NEXT_PUBLIC_WHATSAPP_E164="5511999999999"
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE="Olá! Vim pelo site. Quero solicitar um orçamento."
NEXT_PUBLIC_STORE_ADDRESS="Av. Batatais, 511 - Jardim Paulista, Barueri - SP, 06447-090"
NEXT_PUBLIC_STORE_PHONE="(11) 4303-5991"
NEXT_PUBLIC_STORE_HOURS="Fechado · Abre seg. às 09:30 (confirme no Google)"
NEXT_PUBLIC_GOOGLE_MAPS_QUERY="Marquinhos motos mecanica geral"
NEXT_PUBLIC_GOOGLE_RATING="4,7"
NEXT_PUBLIC_GOOGLE_REVIEWS="4733"
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=""
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/marquinhosmotosbarueri/"
