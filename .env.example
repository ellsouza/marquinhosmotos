# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marquinhos_motos?schema=public"
# Use 1 para usar o catalogo no banco (Prisma). Coloque 0 para usar o catalogo de exemplo.
MM_ENABLE_DB="0"

# App auth (JWT)
AUTH_SECRET="change-me-to-a-long-random-string"
MM_JWT_ISSUER="marquinhos-motos"
MM_JWT_AUDIENCE="web"

# Stripe (opcional, para checkout real por cartao)
STRIPE_SECRET_KEY=""
# Endpoint: /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=""

# OAuth (opcional)
# Google (OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple (Sign in with Apple)
# APPLE_PRIVATE_KEY: chave .p8 (pode usar \\n para quebras de linha no .env)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Public site config
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="Marquinhos Motos Mecanica Geral"
NEXT_PUBLIC_STORE_CITY="Barueri"
NEXT_PUBLIC_STORE_STATE="SP"
NEXT_PUBLIC_HERO_HEADLINE="Pecas e servicos para motos - atendimento rapido em Barueri/SP"
NEXT_PUBLIC_WHATSAPP_E164="5511999999999"
